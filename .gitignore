# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
dist-ssr/
build/
*.local

# Environment variables - NEVER commit these!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Testing
coverage/
.nyc_output/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# TypeScript
*.tsbuildinfo
vite.config.js
vite.config.d.ts

# Vite
*.local

# Debug
debug/
*.debug

# Temporary files
tmp/
temp/
*.tmp

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Server build output
server/dist/
server/node_modules/

# Research data (keep sensitive data out of repo)
data/
