# ===========================================
# Environment Variables for AI Negotiation Platform
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ===========================================

# ---------- Frontend (Vite) ----------

# Backend mode: always "rest" for self-hosted deployment
VITE_BACKEND=rest

# Base URL of the self-hosted Express server (REST API)
VITE_API_URL=http://localhost:3000

# Assistant API endpoint (Ollama proxy on the Express server)
VITE_ASSISTANT_API_URL=http://localhost:3000/api/assistant/query

# ---------- Server ----------
# (also defined in server/.env.example)

# PostgreSQL connection string
DATABASE_URL=postgresql://neg:neg@localhost:5432/negplatform

# Ollama LLM server URL and model
OLLAMA_URL=http://localhost:11434
LLM_MODEL=llama3.2

# Express server port
PORT=3000

# Admin password for the admin panel
ADMIN_PASSWORD=
